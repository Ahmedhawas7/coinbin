# ==========================================
# CoinBin — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in your keys

# Coinbase Developer Platform (CDP) — Required for OnchainKit
# Get yours FREE at: https://portal.cdp.coinbase.com/
NEXT_PUBLIC_ONCHAINKIT_API_KEY=TZTfeoUYBNggPBSFMwU38ltwvl2KuBnQeMrbJYYc0xzJR0HQtmeG3OhTB8uv3q/wfErKQ1/X6ys55FhrXrB+nQ==

# WalletConnect Project ID — Required for WalletConnect support
# Get yours FREE at: https://cloud.walletconnect.com/ → "New Project"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=ydaf9a7d8f98bcee23b28539a29d9ba45

# Alchemy API Key — For discovering ALL tokens (not just known list)
# Get yours FREE at: https://www.alchemy.com/ → Create App on Base
# Leave empty to use the static known-tokens list only
NEXT_PUBLIC_ALCHEMY_KEY=qJWA90VsL3JFFcY7g5nhl

# App URL — Update with your Vercel domain after deployment
NEXT_PUBLIC_APP_URL=https://coinbin.vercel.app

# ─────────────────────────────────────────
# After getting your keys:
# 1. cp .env.example .env.local
# 2. Fill in the values above
# 3. Also update FEE_RECIPIENT in src/config/contracts.ts with your wallet address
# ─────────────────────────────────────────
